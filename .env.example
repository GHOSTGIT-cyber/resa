# Copier en .env (ou définir dans Coolify > Environment Variables).
# ⚠️ Ne JAMAIS committer les vraies valeurs : ce fichier ne contient que des exemples.

# --- Accès dashboard ---
# Mot de passe pour dévoiler les données confidentielles (nom/tél/e-mail)
DASHBOARD_PASSWORD=change-moi
# Secret de signature du cookie de session (longue chaîne aléatoire)
DASHBOARD_SECRET=mets-une-longue-chaine-aleatoire
# URL publique du dashboard (utilisée dans les notifications + URL de la photo des mails)
DASHBOARD_URL=https://resa.efoilcotedazur.fr

# --- Stockage ---
# Dossier de stockage (laisser tel quel ; monter un volume Coolify sur /app/data)
DATA_DIR=/app/data

# --- Sites gérés par CE déploiement ---
# Le BRANDING (nom/pied/téléphone/Google) est défini dans le code (lib/sites.js) par site.
# Le site d'une réservation est détecté par le DOMAINE d'arrivée (resa.efoil-beauvallon.fr, etc.).
# SITES_ENABLED = sites affichés dans le dashboard (boutons de filtre si plusieurs).
#   - Côte d'Azur (mono-site)      : SITES_ENABLED=cotedazur
#   - Beauvallon + Croix-Valmer    : SITES_ENABLED=beauvallon,croixvalmer
SITES_ENABLED=cotedazur

# --- Identité de marque (repli si site inconnu / déploiement générique) ---
# Optionnel : sert de valeurs par défaut quand le site n'est pas dans lib/sites.js.
BRAND_NAME=eFoil Côte d'Azur
BRAND_SITE=https://efoilcotedazur.fr
BRAND_LOGO=https://efoilcotedazur.fr/wp-content/uploads/2026/06/efca-logo.webp
# Photo d'en-tête des mails (laisser vide = /mail-photo.jpg servi par ce dashboard)
BRAND_PHOTO=
# Téléphone affiché dans les mails (display + lien tel: normalisé)
BRAND_PHONE=06 35 30 50 67
BRAND_FOOTER=Mandelieu-la-Napoule & baie de Cannes
# Lien avis Google. Laisser VIDE (BRAND_GOOGLE_REVIEW=) pour MASQUER l'encart (marques sans fiche).
BRAND_GOOGLE_REVIEW=https://maps.app.goo.gl/SmZHJVCmXBzgBV7b9

# --- Notifications WhatsApp (CallMeBot) — OPTIONNEL ---
# Jusqu'à 20 destinataires : WHATSAPP_PHONE (n°1) puis WHATSAPP_PHONE2..WHATSAPP_PHONE20.
# Chaque numéro a SA propre clé apikey CallMeBot (WHATSAPP_APIKEY, APIKEY2, APIKEY3...).
# Format numéro : international SANS le "+" (ex. 33623754582). Vide = ce destinataire est ignoré.
WHATSAPP_PHONE=33623754582
WHATSAPP_APIKEY=
WHATSAPP_PHONE2=
WHATSAPP_APIKEY2=
WHATSAPP_PHONE3=
WHATSAPP_APIKEY3=
WHATSAPP_PHONE4=
WHATSAPP_APIKEY4=

# --- Notifications e-mail (SMTP via nodemailer) — OPTIONNEL ---
# Si SMTP_HOST/SMTP_USER/SMTP_PASS ne sont pas tous définis, l'e-mail est ignoré.
# Marche avec N'IMPORTE QUEL SMTP : OVH, Gmail (app password), Outlook/live, Brevo, etc.
# Exemples :
#   Gmail  : smtp.gmail.com / 587 / SECURE=false / SMTP_USER=ton@gmail.com / SMTP_PASS=<app password 16 car.>
#   Outlook: smtp-mail.outlook.com / 587 / SECURE=false
#   Brevo  : smtp-relay.brevo.com / 587 / SECURE=false (SMTP_USER=login Brevo, EMAIL_FROM=adresse vérifiée)
#   OVH    : ssl0.ovh.net / 465 / SECURE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Adresse expéditeur affichée (facultatif). Si vide, on utilise SMTP_USER.
# Utile avec Brevo/Mailgun/Resend où l'utilisateur SMTP n'est pas l'adresse d'envoi.
# Idée "no-reply" : EMAIL_FROM=noreply@efoilcotedazur.fr (domaine vérifié chez le fournisseur).
EMAIL_FROM=
# Adresse de réponse (facultatif). Où atterrissent les réponses des clients.
# Le mail GÉRANT a déjà Reply-To = e-mail du client (pour répondre direct au client).
EMAIL_REPLY_TO=
# Destinataire(s) du mail gérant : une ou plusieurs adresses séparées par des virgules
OWNER_EMAIL=bakari06@live.fr
# Copie cachée (BCC) ajoutée à TOUS les mails, y compris ceux envoyés aux clients.
# Sert d'archive globale (ex. bakari06@live.fr voit tout ce qui sort).
# Accepte plusieurs adresses séparées par des virgules.
BCC_ALL=

# --- Paiement SumUp (lien simple, OPTIONNEL) ---
# Lien de paiement SumUp (acompte). Si défini, le bouton « Confirmer + 50€ » ajoute
# ce bouton de paiement dans le mail de confirmation. Vide = pas de paiement proposé.
# NB : un lien simple ne remonte PAS le statut « payé » (voir DASHBOARD-HANDOFF.md).
SUMUP_PAYMENT_LINK=
# Libellé du montant affiché dans le mail (facultatif, défaut « 50 € »).
SUMUP_AMOUNT=50 €
