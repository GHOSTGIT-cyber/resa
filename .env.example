# Copier en .env (ou définir dans Coolify > Environment Variables).
# ⚠️ Ne JAMAIS committer les vraies valeurs : ce fichier ne contient que des exemples.

# --- Accès dashboard ---
# Mot de passe pour dévoiler les données confidentielles (nom/tél/e-mail)
DASHBOARD_PASSWORD=change-moi
# Secret de signature du cookie de session (longue chaîne aléatoire)
DASHBOARD_SECRET=mets-une-longue-chaine-aleatoire
# URL publique du dashboard (utilisée dans les notifications)
DASHBOARD_URL=https://resa.bakabi.fr

# --- Stockage ---
# Dossier de stockage (laisser tel quel ; monter un volume Coolify sur /app/data)
DATA_DIR=/app/data

# --- Notifications WhatsApp (CallMeBot) — OPTIONNEL ---
# Jusqu'à 3 destinataires ; chaque numéro a SA propre clé apikey CallMeBot.
# Format numéro : international SANS le "+" (ex. 33623754582). Laisser vide pour désactiver.
WHATSAPP_PHONE=33623754582
WHATSAPP_APIKEY=
WHATSAPP_PHONE2=
WHATSAPP_APIKEY2=
WHATSAPP_PHONE3=
WHATSAPP_APIKEY3=

# --- Notifications e-mail (SMTP via nodemailer) — OPTIONNEL ---
# Si SMTP_HOST/SMTP_USER/SMTP_PASS ne sont pas tous définis, l'e-mail est ignoré.
# Marche avec N'IMPORTE QUEL SMTP : OVH, Gmail (app password), Outlook/live, Brevo, etc.
# Exemples :
#   Gmail  : smtp.gmail.com / 587 / SECURE=false / SMTP_USER=ton@gmail.com / SMTP_PASS=<app password 16 car.>
#   Outlook: smtp-mail.outlook.com / 587 / SECURE=false
#   Brevo  : smtp-relay.brevo.com / 587 / SECURE=false (SMTP_USER=login Brevo, EMAIL_FROM=adresse vérifiée)
#   OVH    : ssl0.ovh.net / 465 / SECURE=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Adresse expéditeur affichée (facultatif). Si vide, on utilise SMTP_USER.
# Utile avec Brevo/Mailgun où l'utilisateur SMTP n'est pas l'adresse d'envoi.
EMAIL_FROM=
# Destinataire(s) du mail gérant : une ou plusieurs adresses séparées par des virgules
OWNER_EMAIL=bakari06@live.fr
