# Copier en .env (ou définir dans Coolify > Environment Variables)

# Mot de passe pour dévoiler les données confidentielles (nom/tél/e-mail) dans le dashboard
DASHBOARD_PASSWORD=change-moi

# Secret de signature du cookie de session (mets une longue chaîne aléatoire)
DASHBOARD_SECRET=mets-une-longue-chaine-aleatoire

# Dossier de stockage (laisser tel quel ; monter un volume Coolify sur /app/data)
DATA_DIR=/app/data

# (OPTIONNEL) Notification WhatsApp côté serveur via CallMeBot.
# Laisser vide pour désactiver (les notifs côté navigateur du site continuent de marcher).
WHATSAPP_PHONE=33623754582
WHATSAPP_APIKEY=
